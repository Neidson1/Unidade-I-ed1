#include <stdio.h>
#include <stdlib.h>

int main() {
    int n_inimigos;
    int *ponteiro_onda;

    // Entrada da quantidade de inimigos
    printf("Digite a quantidade de inimigos da onda: ");
    scanf("%d", &n_inimigos);

    // Alocação dinâmica do vetor
    ponteiro_onda = (int *) malloc(n_inimigos * sizeof(int));

    // Verificação de falha na alocação
    if (ponteiro_onda == NULL) {
        printf("Erro: falha na alocacao de memoria!\n");
        return 1;
    }

    // Preenchendo a onda de inimigos
    for (int i = 0; i < n_inimigos; i++) {
        printf("Digite o ID do inimigo %d: ", i + 1);
        scanf("%d", &ponteiro_onda[i]);
    }

    // Listando os inimigos
    printf("Onda de inimigos criada com sucesso! IDs: ");
    for (int i = 0; i < n_inimigos; i++) {
        printf("%d ", ponteiro_onda[i]);
    }

    printf("\n");

    // Liberando memória
    free(ponteiro_onda);
    ponteiro_onda = NULL;

    return 0;
}
