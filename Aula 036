#include <stdio.h>
#include <stdlib.h>

// Estrutura da Moeda
struct Moeda {
    int posicao_x;
    int posicao_y;
    int valor;
};

int main() {
    int quantidade;

    // Pergunta quantidade de moedas
    printf("Quantas moedas existem no nivel? ");
    scanf("%d", &quantidade);

    // Alocação dinâmica
    struct Moeda *moedas = (struct Moeda *) malloc(quantidade * sizeof(struct Moeda));

    if (moedas == NULL) {
        printf("Erro de alocacao de memoria!\n");
        return 1;
    }

    // Cadastro das moedas
    for (int i = 0; i < quantidade; i++) {
        printf("\nMoeda %d\n", i + 1);

        printf("Posicao X: ");
        scanf("%d", &moedas[i].posicao_x);

        printf("Posicao Y: ");
        scanf("%d", &moedas[i].posicao_y);

        printf("Valor: ");
        scanf("%d", &moedas[i].valor);
    }

    // Cálculo dos pontos
    int total_pontos = 0;

    for (int i = 0; i < quantidade; i++) {
        total_pontos += moedas[i].valor;
    }

    // Exibição do resultado
    printf("\nPontuacao maxima do nivel: %d\n", total_pontos);

    // Liberação de memória
    free(moedas);

    return 0;
}
