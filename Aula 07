#include <stdio.h>

// Função para ler o cenário
void ler_cenario(int n, int *cenario) {
    for (int i = 0; i < n; i++) {
        scanf("%d", (cenario + i));
    }
}

int main() {
    int n;

    // Leitura do tamanho do cenário
    scanf("%d", &n);

    int cenario[n]; // vetor de tamanho n

    // Leitura do cenário
    ler_cenario(n, cenario);

    // Posiciona o power-up no primeiro bloco 1 encontrado
    for (int i = 0; i < n; i++) {
        if (*(cenario + i) == 1) {
            *(cenario + i) = 2;
            break;
        }
    }

    // Impressão do cenário modificado
    for (int i = 0; i < n; i++) {
        printf("%d ", *(cenario + i));
    }

    return 0;
}
