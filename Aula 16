#include <stdio.h>
#include <string.h>

int main() {
    char inventario[5][20];
    char item_necessario[20];
    int encontrado = 0;

    // Leitura dos itens do inventário
    for (int i = 0; i < 5; i++) {
        printf("Digite o item %d: ", i + 1);
        scanf(" %[^\n]", inventario[i]);
    }

    // Leitura do item necessário
    printf("Digite o item necessário para abrir a porta: ");
    scanf(" %[^\n]", item_necessario);

    // Verificação do inventário
    for (int i = 0; i < 5; i++) {
        if (strcmp(inventario[i], item_necessario) == 0) {
            encontrado = 1;
            break;
        }
    }

    // Resultado
    if (encontrado) {
        printf("Porta aberta!\n");
    } else {
        printf("Voce nao tem o item necessario.\n");
    }

    return 0;
}
