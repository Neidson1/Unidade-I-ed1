#include <stdio.h>
#include <stdlib.h>

int main() {
    float *ponteiro_altura_salto_duplo = NULL;

    // Status inicial
    printf("Jogador ainda nao possui o Salto Duplo.\n");

    // Coleta do power-up (alocação dinâmica)
    ponteiro_altura_salto_duplo = (float *) malloc(sizeof(float));

    // Verificação da alocação
    if (ponteiro_altura_salto_duplo != NULL) {

        // Atribui o valor da habilidade
        *ponteiro_altura_salto_duplo = 15.5;

        // Status final
        printf("Pena Dourada coletada! Altura do Salto Duplo: %.2f\n",
               *ponteiro_altura_salto_duplo);

        // Liberação de memória (boa prática)
        free(ponteiro_altura_salto_duplo);
        // Em um jogo real, essa linha seria usada para liberar a memória
        // quando o power-up não fosse mais necessário.
    }

    return 0;
}
